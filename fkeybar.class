#!/bin/bash
# fkeybar.class - Function key bar (MC style) using ba.sh

declare -Ag __FKEYBAR___properties=()
__FKEYBAR___properties[active_layer]=0

__FKEYBAR__.property(){
    if [ "$2" = "=" ]; then
        __FKEYBAR___properties[$1]="$3"
    else
        echo "${__FKEYBAR___properties[$1]}"
    fi
}

# Property accessors
__FKEYBAR__.row(){          __FKEYBAR__.property row          "$@"; }
__FKEYBAR__.width(){        __FKEYBAR__.property width        "$@"; }
__FKEYBAR__.active_layer(){ __FKEYBAR__.property active_layer "$@"; }

# Render function key bar
__FKEYBAR__.render(){
    fkeybar.update_labels
    local layer=$(__FKEYBAR__.active_layer)
    local row=$(__FKEYBAR__.row)
    local width=$(__FKEYBAR__.width)

    local labels=("${__FKEYBAR_LABELS[@]}")
    while [ ${#labels[@]} -lt 10 ]; do
        labels+=("")
    done

    tui.cursor.move $row 1

    # Layer indicator: "L0" etc, white on black, 2 chars
    tui.color.white
    tui.color.bg_black
    printf "L%s" "$layer"

    # 10 fkey slots filling remaining width
    local remaining=$(( width - 2 ))
    local key_width=$(( remaining / 10 ))

    for i in {0..9}; do
        local num=$(( i + 1 ))
        local label="${labels[$i]}"

        # Key number: white on black
        tui.color.white
        tui.color.bg_black
        if [ $num -lt 10 ]; then
            printf " %s" "$num"
        else
            printf "%s" "$num"
        fi

        # Label: black on cyan
        tui.color.black
        tui.color.bg_cyan
        printf "%-$(( key_width - 2 ))s" "$label"
    done

    tui.color.reset
}

# ============================================================================
# Key registration, layer state, and dispatch
# Note: these use literal 'fkeybar.' prefix so they are NOT substituted by
# the ba.sh constructor (which only replaces __FKEYBAR__).
# ============================================================================

declare -Ag __MODULE_KEYS=()
declare -Ag __MODULE_KEY_LABELS=()
declare -Ag __MODULE_KEY_LABEL_FUNCS=()
declare -ag __FKEYBAR_LABELS=()
__HACKFM_FKEY_LABEL=""

fkeybar.register_key() {
    local key="$1"
    local func="$2"
    local label="${3:-}"
    if [ -n "${__MODULE_KEYS[$key]+x}" ]; then
        __MODULE_KEYS[$key]="${__MODULE_KEYS[$key]} $func"
    else
        __MODULE_KEYS[$key]="$func"
    fi
    if [ -n "$label" ]; then
        __MODULE_KEY_LABELS[$key]="$label"
    fi
}

# Register a dynamic label callback for a key.
# The callback sets __HACKFM_FKEY_LABEL to claim the label, or leaves it empty to pass.
# Usage: fkeybar.register_key_label KEY FUNC
fkeybar.register_key_label() {
    local key="$1"
    local func="$2"
    if [ -n "${__MODULE_KEY_LABEL_FUNCS[$key]+x}" ]; then
        __MODULE_KEY_LABEL_FUNCS[$key]="${__MODULE_KEY_LABEL_FUNCS[$key]} $func"
    else
        __MODULE_KEY_LABEL_FUNCS[$key]="$func"
    fi
}

# Recompute __FKEYBAR_LABELS for the current layer
fkeybar.update_labels() {
    local i offset
    offset=$(( $(main_fkeybar.active_layer) * 10 ))
    __FKEYBAR_LABELS=()
    for ((i=1; i<=10; i++)); do
        local key="F$(( i + offset ))"
        local label=""
        if [ -n "${__MODULE_KEY_LABEL_FUNCS[$key]+x}" ]; then
            local cb
            for cb in ${__MODULE_KEY_LABEL_FUNCS[$key]}; do
                __HACKFM_FKEY_LABEL=""
                $cb
                if [ -n "$__HACKFM_FKEY_LABEL" ]; then
                    label="$__HACKFM_FKEY_LABEL"
                    break
                fi
            done
        fi
        if [ -z "$label" ]; then
            label="${__MODULE_KEY_LABELS[$key]:-}"
        fi
        __FKEYBAR_LABELS+=("$label")
    done
}

fkeybar.layer_count() {
    local max_fkey=0
    local key
    for key in "${!__MODULE_KEYS[@]}"; do
        if [[ "$key" =~ ^F([0-9]+)$ ]]; then
            local n="${BASH_REMATCH[1]}"
            [ "$n" -gt "$max_fkey" ] && max_fkey="$n"
        fi
    done
    if [ "$max_fkey" -eq 0 ]; then
        echo 1
    else
        echo $(( (max_fkey - 1) / 10 + 1 ))
    fi
}

fkeybar.layer_next() {
    local total current
    total=$(fkeybar.layer_count)
    current=$(main_fkeybar.active_layer)
    main_fkeybar.active_layer = $(( (current + 1) % total ))
    draw_main_frame
}

fkeybar.layer_prev() {
    local total current
    total=$(fkeybar.layer_count)
    current=$(main_fkeybar.active_layer)
    main_fkeybar.active_layer = $(( (current - 1 + total) % total ))
    draw_main_frame
}

fkeybar.dispatch_key() {
    local key="$1"
    if [[ "$key" =~ ^[A-Za-z0-9_-]+$ ]] && [ -n "${__MODULE_KEYS[$key]+x}" ]; then
        local _handler
        for _handler in ${__MODULE_KEYS[$key]}; do
            if $_handler; then return 0; fi
        done
    fi
    return 1
}
