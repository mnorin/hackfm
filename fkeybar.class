#!/bin/bash
# fkeybar.class - Function key bar (MC style) using ba.sh

declare -Ag __FKEYBAR___properties=()

__FKEYBAR__.property(){
    if [ "$2" = "=" ]; then
        __FKEYBAR___properties[$1]="$3"
    else
        echo "${__FKEYBAR___properties[$1]}"
    fi
}

# Property accessors
__FKEYBAR__.row(){   __FKEYBAR__.property row   "$@"; }
__FKEYBAR__.width(){ __FKEYBAR__.property width "$@"; }

# Render function key bar
# Usage: fkeybar.render layer "Label1" "Label2" ... "Label10"
__FKEYBAR__.render(){
    local layer="$1"
    shift
    local row=$(__FKEYBAR__.row)
    local width=$(__FKEYBAR__.width)

    local labels=("$@")
    while [ ${#labels[@]} -lt 10 ]; do
        labels+=("")
    done

    tui.cursor.move $row 1

    # Layer indicator: "L0" etc, white on black, 2 chars
    tui.color.white
    tui.color.bg_black
    printf "L%s" "$layer"

    # 10 fkey slots filling remaining width
    local remaining=$(( width - 2 ))
    local key_width=$(( remaining / 10 ))

    for i in {0..9}; do
        local num=$(( i + 1 ))
        local label="${labels[$i]}"

        # Key number: white on black
        tui.color.white
        tui.color.bg_black
        if [ $num -lt 10 ]; then
            printf " %s" "$num"
        else
            printf "%s" "$num"
        fi

        # Label: black on cyan
        tui.color.black
        tui.color.bg_cyan
        printf "%-$(( key_width - 2 ))s" "$label"
    done

    tui.color.reset
}
