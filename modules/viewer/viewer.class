#!/bin/bash
# viewer.class - File viewer using ba.sh

# Load dependencies
. "$HACKFM_DIR/title.h"
. "$HACKFM_DIR/fkeybar.h"

declare -Ag __VIEWER___properties=()

__VIEWER__.property(){
    if [ "$2" = "=" ]; then
        __VIEWER___properties[$1]="$3"
    else
        echo "${__VIEWER___properties[$1]}"
    fi
}

# Property accessors
__VIEWER__.filepath(){     __VIEWER__.property filepath     "$@"; }
__VIEWER__.scroll(){       __VIEWER__.property scroll       "$@"; }
__VIEWER__.file_offset(){  __VIEWER__.property file_offset  "$@"; }
__VIEWER__.file_total(){   __VIEWER__.property file_total   "$@"; }
__VIEWER__.use_window(){   __VIEWER__.property use_window   "$@"; }
__VIEWER__.rows(){         __VIEWER__.property rows         "$@"; }
__VIEWER__.cols(){         __VIEWER__.property cols         "$@"; }

# File lines array (windowed buffer)
declare -ag __VIEWER___lines=()

# Window constants
VIEWER_WINDOW_SIZE=1000       # max lines kept in buffer
VIEWER_LOAD_THRESHOLD=200     # load more when within this many lines of buffer edge

# ============================================================================
# Append
# ============================================================================
# Append a processed line as cols-wide chunks into __VIEWER___lines
# ============================================================================
__VIEWER__._append_chunks(){
    local line="$1"
    local cols="$2"
    local len=${#line}
    if [ "$len" -eq 0 ]; then
        __VIEWER___lines+=("")
    else
        local pos=0
        while [ $pos -lt $len ]; do
            __VIEWER___lines+=("${line:$pos:$cols}")
            pos=$(( pos + cols ))
        done
    fi
}

# ============================================================================
# Load
# ============================================================================

__VIEWER__.load(){
    local filepath="$1"

    __VIEWER__.filepath = "$filepath"
    __VIEWER___lines=()
    __VIEWER__.scroll = 0
    __VIEWER__.file_offset = 0
    __VIEWER__.file_total = ""
    __VIEWER__.use_window = 0

    local total
    total=$(awk 'END{print NR}' "$filepath" 2>/dev/null || echo "0")
    __VIEWER__.file_total = "$total"

    local cols=$(__VIEWER__.cols)

    if [ "$total" -le "$VIEWER_WINDOW_SIZE" ]; then
        while IFS= read -r line; do
            line="${line%$'\r'}"
            __VIEWER__._append_chunks "$line" "$cols"
        done < <(tr '\000-\010\013-\037\177' '.' < "$filepath")
    else
        __VIEWER__.use_window = 1
        __VIEWER__._load_window 0
    fi
}

# Load a window of lines starting at file line $1 (0-based)
# Fills __VIEWER___lines with up to VIEWER_WINDOW_SIZE lines
__VIEWER__._load_window(){
    local from_line="$1"
    local filepath=$(__VIEWER__.filepath)
    local total=$(__VIEWER__.file_total)

    [ "$from_line" -lt 0 ] && from_line=0
    local max_start=$(( total - VIEWER_WINDOW_SIZE ))
    [ $max_start -lt 0 ] && max_start=0
    [ "$from_line" -gt "$max_start" ] && from_line=$max_start

    __VIEWER___lines=()
    __VIEWER__.file_offset = "$from_line"

    local cols=$(__VIEWER__.cols)
    local count=0

    while IFS= read -r line; do
        line="${line%$'\r'}"
        __VIEWER__._append_chunks "$line" "$cols"
        count=$(( count + 1 ))
        [ $count -ge $VIEWER_WINDOW_SIZE ] && break
    done < <(tail -n +"$((from_line + 1))" "$filepath" 2>/dev/null | tr '\000-\010\013-\037\177' '.')
}

# ============================================================================
# Display
# ============================================================================

__VIEWER__.display_content(){
    local row=2
    local file_offset=$(__VIEWER__.file_offset)

    # Set blue background once for the entire content area
    tui.color.bg_blue
    tui.color.white
    tui.cursor.move 2 1

    for ((i=scroll; i<scroll+max_rows && i<total_lines; i++)); do
        local arr_idx=$(( i - file_offset ))
        tui.cursor.move $row 1

        local display_line="${__VIEWER___lines[$arr_idx]}"
        display_line="${display_line//$'\t'/        }"
        local display_len=$(printf '%s' "$display_line" | wc -m)
        if [ "$display_len" -gt "$cols" ]; then
            display_line=$(printf '%s' "$display_line" | cut -c1-$((cols - 3)))
            display_line+="..."
        fi

        printf '%s' "$display_line"
        printf '\033[K'
        row=$(( row + 1 ))
    done

    # Fill remaining rows with blue (never past fkey bar)
    local content_end=$(( rows - 1 ))
    while [ $row -le $content_end ]; do
        tui.cursor.move $row 1
        printf '\033[K'
        row=$(( row + 1 ))
    done

    tui.style.reset
}

# Check if we need to slide the window and do so
__VIEWER__._check_window(){
    local use_window=$(__VIEWER__.use_window)
    [ "$use_window" != "1" ] && return

    local file_offset=$(__VIEWER__.file_offset)
    local arr_size=${#__VIEWER___lines[@]}
    local arr_scroll=$(( scroll - file_offset ))

    # Near bottom edge - slide window down
    if [ $(( arr_size - arr_scroll )) -lt $VIEWER_LOAD_THRESHOLD ] && \
       [ $(( file_offset + arr_size )) -lt $total_lines ]; then
        # New window starts VIEWER_LOAD_THRESHOLD lines before current scroll
        local new_offset=$(( scroll - VIEWER_LOAD_THRESHOLD ))
        __VIEWER__._load_window "$new_offset"
        return
    fi

    # Near top edge - slide window up
    if [ "$arr_scroll" -lt $VIEWER_LOAD_THRESHOLD ] && [ "$file_offset" -gt 0 ]; then
        local new_offset=$(( scroll - VIEWER_WINDOW_SIZE + VIEWER_LOAD_THRESHOLD ))
        __VIEWER__._load_window "$new_offset"
        return
    fi
}

# ============================================================================
# SEARCH
# ============================================================================

# Search state
__VIEWER___search_pattern=""
__VIEWER___search_case=1
__VIEWER___search_backwards=0
__VIEWER___search_whole=0

__VIEWER__._search_draw_all(){
    local dr=$1 dc=$2 dw=$3 dh=$4 pattern=$5 case_s=$6 back_s=$7 whole_s=$8 focus=$9
    local cursor_pos=${10:-${#pattern}}
    local inner=$(( dw - 4 ))

    # Input field
    tui.cursor.move $((dr + 3)) $((dc + 2))
    if [ $focus -eq 0 ]; then
        tui.color.bg_cyan; tui.color.black
    else
        tui.color.bg_white; tui.color.black
    fi
    local display_start=0
    [ $cursor_pos -ge $inner ] && display_start=$(( cursor_pos - inner + 1 ))
    local display_pat="${pattern:$display_start:$inner}"
    printf " %-${inner}s" "$display_pat"
    tui.color.reset

    # Checkboxes
    local i label mark
    local cb_labels=("Case sensitive" "Backwards" "Whole word")
    local cb_vals=($case_s $back_s $whole_s)
    for ((i=0; i<3; i++)); do
        tui.cursor.move $((dr + 5 + i)) $((dc + 4))
        if [ $(( i + 1 )) -eq $focus ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        mark=" "
        [ "${cb_vals[$i]}" -eq 1 ] && mark="X"
        printf "[%s] %-20s" "$mark" "${cb_labels[$i]}"
        tui.color.reset
    done

    # Buttons — OK is default
    local btn_row=$(( dr + dh - 2 ))
    local ok_col=$(( dc + dw/2 - 9 ))
    tui.cursor.move $btn_row $ok_col
    if [ $focus -eq 4 ]; then
        tui.color.bg_cyan; tui.color.black
    else
        tui.color.bg_white; tui.color.black
    fi
    printf "[< OK >]"
    tui.color.reset
    tui.color.bg_white; tui.color.black
    printf "   "
    if [ $focus -eq 5 ]; then
        tui.color.bg_cyan; tui.color.black
    else
        tui.color.bg_white; tui.color.black
    fi
    printf "[ Cancel ]"
    tui.color.reset

    # Cursor in input
    if [ $focus -eq 0 ]; then
        local cur_col=$(( dc + 2 + (cursor_pos - display_start) + 1 ))
        tui.cursor.move $((dr + 3)) $cur_col
    fi
}

__VIEWER__._search_dialog(){
    local rows=$1 cols=$2
    local dw=52 dh=11
    local dr=$(( (rows - dh) / 2 ))
    local dc=$(( (cols - dw) / 2 ))
    local r

    tui.region.reset
    tui.screen.wrap_on

    # Shadow
    tui.color.bg_black
    for ((r=dr+1; r<dr+dh+1; r++)); do
        tui.cursor.move $r $(( dc + 2 ))
        printf "%${dw}s" ""
    done
    tui.color.reset

    # Background
    tui.color.bg_white; tui.color.black
    for ((r=dr; r<dr+dh; r++)); do
        tui.cursor.move $r $dc
        printf "%${dw}s" ""
    done

    # Border + title
    tui.color.bg_white; tui.color.black
    tui.box.draw $dr $dc $dw $dh
    tui.cursor.move $dr $(( dc + (dw - 8) / 2 ))
    tui.color.bg_white; tui.color.black
    printf " Search "
    tui.color.reset

    # Label
    tui.cursor.move $(( dr + 2 )) $(( dc + 2 ))
    tui.color.bg_white; tui.color.black
    printf "Search for:"
    tui.color.reset

    local pattern="$__VIEWER___search_pattern"
    local case_s=$__VIEWER___search_case
    local back_s=$__VIEWER___search_backwards
    local whole_s=$__VIEWER___search_whole
    local focus=0
    local cursor_pos=${#pattern}

    __VIEWER__._search_draw_all $dr $dc $dw $dh "$pattern" $case_s $back_s $whole_s $focus $cursor_pos
    tui.cursor.show

    local key
    while true; do
        key=$(tui.input.key 2>&1) || continue
        case "$key" in
            TAB|DOWN)
                focus=$(( (focus + 1) % 6 ))
                ;;
            SHIFT-TAB|UP)
                focus=$(( (focus + 5) % 6 ))
                ;;
            LEFT)
                if [ $focus -eq 0 ]; then
                    [ $cursor_pos -gt 0 ] && cursor_pos=$(( cursor_pos - 1 ))
                elif [ $focus -eq 5 ]; then
                    focus=4
                fi
                ;;
            RIGHT)
                if [ $focus -eq 0 ]; then
                    [ $cursor_pos -lt ${#pattern} ] && cursor_pos=$(( cursor_pos + 1 ))
                elif [ $focus -eq 4 ]; then
                    focus=5
                fi
                ;;
            HOME)
                [ $focus -eq 0 ] && cursor_pos=0
                ;;
            END)
                [ $focus -eq 0 ] && cursor_pos=${#pattern}
                ;;
            SPACE)
                [ $focus -eq 1 ] && case_s=$(( 1 - case_s ))
                [ $focus -eq 2 ] && back_s=$(( 1 - back_s ))
                [ $focus -eq 3 ] && whole_s=$(( 1 - whole_s ))
                ;;
            ENTER)
                if [ $focus -eq 5 ]; then
                    tui.cursor.hide
                    return 1
                fi
                __VIEWER___search_pattern="$pattern"
                __VIEWER___search_case=$case_s
                __VIEWER___search_backwards=$back_s
                __VIEWER___search_whole=$whole_s
                tui.cursor.hide
                return 0
                ;;
            ESC)
                tui.cursor.hide
                return 1
                ;;
            BACKSPACE)
                if [ $focus -eq 0 ] && [ $cursor_pos -gt 0 ]; then
                    pattern="${pattern:0:$((cursor_pos-1))}${pattern:$cursor_pos}"
                    cursor_pos=$(( cursor_pos - 1 ))
                fi
                ;;
            DELETE)
                if [ $focus -eq 0 ] && [ $cursor_pos -lt ${#pattern} ]; then
                    pattern="${pattern:0:$cursor_pos}${pattern:$((cursor_pos+1))}"
                fi
                ;;
            *)
                if [ ${#key} -eq 1 ] && [ $focus -eq 0 ]; then
                    pattern="${pattern:0:$cursor_pos}${key}${pattern:$cursor_pos}"
                    cursor_pos=$(( cursor_pos + 1 ))
                fi
                ;;
        esac
        __VIEWER__._search_draw_all $dr $dc $dw $dh "$pattern" $case_s $back_s $whole_s $focus $cursor_pos
    done
}

__VIEWER__._search_exec(){
    local start=$1
    local pattern="$__VIEWER___search_pattern"
    [ -z "$pattern" ] && return 1

    local grep_flags="-n"
    [ $__VIEWER___search_case -eq 0 ] && grep_flags="$grep_flags -i"
    [ $__VIEWER___search_whole -eq 1 ] && grep_flags="$grep_flags -w"

    local filepath=$(__VIEWER__.filepath)
    local found

    if [ $__VIEWER___search_backwards -eq 0 ]; then
        found=$(grep $grep_flags -- "$pattern" "$filepath" 2>/dev/null \
            | awk -F: -v s="$((start + 2))" '$1 >= s {print $1; exit}')
    else
        found=$(grep $grep_flags -- "$pattern" "$filepath" 2>/dev/null \
            | awk -F: -v s="$start" '$1 < s {last=$1} END {if(last) print last}')
    fi

    if [ -n "$found" ]; then
        scroll=$(( found - 1 ))
        return 0
    fi
    return 1
}

__VIEWER__._search_not_found(){
    local rows=$1 cols=$2
    local msg="Not found. Search from beginning?"
    local dw=$(( ${#msg} + 8 ))
    local dh=7
    local dr=$(( (rows - dh) / 2 ))
    local dc=$(( (cols - dw) / 2 ))
    local r

    tui.region.reset
    tui.screen.wrap_on

    # Shadow
    tui.color.bg_black
    for ((r=dr+1; r<dr+dh+1; r++)); do
        tui.cursor.move $r $(( dc + 2 ))
        printf "%${dw}s" ""
    done
    tui.color.reset

    # Background + border
    tui.color.bg_white; tui.color.black
    for ((r=dr; r<dr+dh; r++)); do
        tui.cursor.move $r $dc
        printf "%${dw}s" ""
    done
    tui.color.bg_white; tui.color.black
    tui.box.draw $dr $dc $dw $dh
    tui.cursor.move $dr $(( dc + (dw - 13) / 2 ))
    tui.color.bg_white; tui.color.black
    printf " Not Found "
    tui.color.reset

    tui.cursor.move $(( dr + 2 )) $(( dc + 4 ))
    tui.color.bg_white; tui.color.black
    printf "%s" "$msg"
    tui.color.reset

    local sel=0
    local key
    while true; do
        tui.cursor.move $(( dr + 5 )) $(( dc + dw/2 - 8 ))
        if [ $sel -eq 0 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "[< Yes >]"
        tui.color.reset
        tui.color.bg_white; tui.color.black
        printf "   "
        if [ $sel -eq 1 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "[ No ]"
        tui.color.reset

        key=$(tui.input.key 2>&1) || continue
        case "$key" in
            LEFT|RIGHT|TAB|UP|DOWN) sel=$(( 1 - sel )) ;;
            ENTER) [ $sel -eq 0 ] && return 0; return 1 ;;
            ESC|n|N) return 1 ;;
            y|Y) return 0 ;;
        esac
    done
}


__VIEWER__.show(){
    local filepath=$(__VIEWER__.filepath)
    local filename=$(basename "$filepath")

    if [ -z "$filepath" ]; then
        return 1
    fi

    title __VIEWER___title
    fkeybar __VIEWER___fkeybar

    local size
    size=$(tui.screen.size)
    __HACKFM_ROWS=${size% *}
    __HACKFM_COLS=${size#* }
    tui.cursor.hide
    local rows=$__HACKFM_ROWS
    local cols=$__HACKFM_COLS
    local content_height=$(( rows - 2 ))
    # Override with explicit properties if set
    local prop_rows=$(__VIEWER__.rows)
    local prop_cols=$(__VIEWER__.cols)
    [ -n "$prop_rows" ] && rows=$prop_rows
    [ -n "$prop_cols" ] && cols=$prop_cols && content_height=$(( rows - 2 ))
    local use_window=$(__VIEWER__.use_window)
    local file_offset=$(__VIEWER__.file_offset)

    # total_lines: for windowed mode use file_total, otherwise array size
    local total_lines
    if [ "$use_window" = "1" ]; then
        total_lines=$(__VIEWER__.file_total)
    else
        total_lines=${#__VIEWER___lines[@]}
    fi

    # Only switch to alt screen if running standalone (not embedded in hackfm)
    local _embedded=0
    [ -n "${HACKFM_RUNNING:-}" ] && _embedded=1
    [ $_embedded -eq 0 ] && tui.screen.alt
    tui.cursor.hide
    tui.screen.clear
    __VIEWER___title.width = $cols
    __VIEWER___title.text_left = " File: $filename"
    __VIEWER___title.render
    __VIEWER___fkeybar.row = $rows
    __VIEWER___fkeybar.width = $cols
    __FKEYBAR_LABELS=("Help" "" "Quit" "" "" "" "Search" "" "" "Quit")
    __VIEWER___fkeybar.render

    # Disable line wrap and lock scroll region to content area only.
    # This means no stray output or implicit terminal scroll can ever touch
    # the fkey bar at row $rows \u2014 it is physically outside the scroll region.
    tui.screen.wrap_off
    tui.region.set 2 $((rows - 1))

    if [ "$total_lines" -eq 0 ]; then
        tui.cursor.move 3 1
        tui.color.bg_blue
        tui.color.white
        echo "<empty file>"
        tui.color.reset
    fi

    local scroll=$(__VIEWER__.scroll)
    local max_rows=$content_height
    local current_line pct

    # Draw title before initial content display
    local current_line=$((scroll + 1))
    local pct=0
    [ "$total_lines" -gt 0 ] && pct=$(( scroll * 100 / total_lines ))
    __VIEWER___title.text_left = " File: $filename"
    __VIEWER___title.text_right = "Line $current_line (~$pct%) "
    __VIEWER___title.render
    __VIEWER__.display_content

    while true; do
        local key=$(tui.input.key)
        local old_scroll=$scroll

        case "$key" in
            ESC|F3|F10)
                break
                ;;
            F7)
                tui.region.reset
                tui.screen.wrap_on
                __VIEWER__._search_dialog $rows $cols
                local dlg_result=$?
                tui.screen.wrap_off
                tui.region.set 2 $(( rows - 1 ))
                __VIEWER__.display_content
                __VIEWER___title.render
                __VIEWER___fkeybar.render
                if [ $dlg_result -eq 0 ] && [ -n "$__VIEWER___search_pattern" ]; then
                    if ! __VIEWER__._search_exec $scroll; then
                        tui.region.reset
                        tui.screen.wrap_on
                        if __VIEWER__._search_not_found $rows $cols; then
                            __VIEWER__._search_exec 0 || true
                        fi
                        tui.screen.wrap_off
                        tui.region.set 2 $(( rows - 1 ))
                        __VIEWER__.display_content
                        __VIEWER___title.render
                        __VIEWER___fkeybar.render
                    fi
                fi
                ;;
            n)
                if [ -n "$__VIEWER___search_pattern" ]; then
                    if ! __VIEWER__._search_exec $scroll; then
                        tui.region.reset
                        tui.screen.wrap_on
                        if __VIEWER__._search_not_found $rows $cols; then
                            __VIEWER__._search_exec 0 || true
                        fi
                        tui.screen.wrap_off
                        tui.region.set 2 $(( rows - 1 ))
                        __VIEWER__.display_content
                        __VIEWER___title.render
                        __VIEWER___fkeybar.render
                    fi
                fi
                ;;
            N)
                if [ -n "$__VIEWER___search_pattern" ]; then
                    __VIEWER___search_backwards=$(( 1 - __VIEWER___search_backwards ))
                    if ! __VIEWER__._search_exec $scroll; then
                        tui.region.reset
                        tui.screen.wrap_on
                        scroll=$total_lines
                        if __VIEWER__._search_not_found $rows $cols; then
                            __VIEWER__._search_exec $scroll || true
                        fi
                        tui.screen.wrap_off
                        tui.region.set 2 $(( rows - 1 ))
                        __VIEWER__.display_content
                        __VIEWER___title.render
                        __VIEWER___fkeybar.render
                    fi
                    __VIEWER___search_backwards=$(( 1 - __VIEWER___search_backwards ))
                fi
                ;;
            UP)
                [ $scroll -gt 0 ] && scroll=$(( scroll - 1 ))
                ;;
            DOWN)
                [ $scroll -lt $((total_lines - max_rows)) ] && scroll=$(( scroll + 1 )) || true
                ;;
            PAGEUP)
                scroll=$((scroll - max_rows))
                [ $scroll -lt 0 ] && scroll=0
                ;;
            PAGEDOWN)
                scroll=$((scroll + max_rows))
                local max_scroll=$((total_lines - max_rows))
                [ $max_scroll -lt 0 ] && max_scroll=0
                [ $scroll -gt $max_scroll ] && scroll=$max_scroll
                ;;
            HOME)
                scroll=0
                ;;
            END)
                scroll=$((total_lines - max_rows))
                [ $scroll -lt 0 ] && scroll=0
                ;;
        esac

        # Check if window needs sliding (no-op for fully loaded files)
        local old_offset=$file_offset
        __VIEWER__._check_window
        # Refresh locals that may have changed after window slide
        file_offset=$(__VIEWER__.file_offset)
        local window_slid=0
        [ "$file_offset" != "$old_offset" ] && window_slid=1

        local scroll_delta=$((scroll - old_scroll))

        if [ $window_slid -eq 1 ] || [ $scroll_delta -ne 0 ]; then
            if [ $window_slid -eq 0 ] && [ $scroll_delta -eq 1 ]; then
                # Scrolled down by 1 - scroll region up, draw new bottom line
                tui.color.bg_blue
                tui.color.white
                tui.cursor.move $((rows - 1)) 1
                tui.region.scroll_up
                local new_line_idx=$((scroll + max_rows - 1))
                if [ $new_line_idx -lt $total_lines ]; then
                    local arr_idx=$(( new_line_idx - file_offset ))
                    tui.cursor.move $((rows - 1)) 1
                    local display_line="${__VIEWER___lines[$arr_idx]}"
                    display_line="${display_line//$'\t'/        }"
                    local display_len=$(printf '%s' "$display_line" | wc -m)
                    if [ "$display_len" -gt "$cols" ]; then
                        display_line=$(printf '%s' "$display_line" | cut -c1-$((cols - 3)))
                        display_line+="..."
                    fi
                    printf '%s' "$display_line"
                    printf '\033[K'
                fi
                tui.style.reset

            elif [ $window_slid -eq 0 ] && [ $scroll_delta -eq -1 ]; then
                # Scrolled up by 1 - scroll region down, draw new top line
                tui.color.bg_blue
                tui.color.white
                tui.cursor.move 2 1
                tui.region.scroll_down
                local arr_idx=$(( scroll - file_offset ))
                tui.cursor.move 2 1
                local display_line="${__VIEWER___lines[$arr_idx]}"
                display_line="${display_line//$'\t'/        }"
                local display_len=$(printf '%s' "$display_line" | wc -m)
                if [ "$display_len" -gt "$cols" ]; then
                    display_line=$(printf '%s' "$display_line" | cut -c1-$((cols - 3)))
                    display_line+="..."
                fi
                printf '%s' "$display_line"
                printf '\033[K'
                tui.style.reset

            else
                # Page jump or window slide - full redraw
                __VIEWER__.display_content
            fi

            # Update title with new line number
            current_line=$((scroll + 1))
            [ "$total_lines" -gt 0 ] && pct=$(( scroll * 100 / total_lines )) || pct=0
            __VIEWER___title.text_left = " File: $filename"
            __VIEWER___title.text_right = "Line $current_line (~$pct%) "
            __VIEWER___title.render
        fi
    done

    __VIEWER__.scroll = $scroll

    # Restore terminal state
    tui.region.reset
    tui.screen.wrap_on
}

# Open file (convenience method)
__VIEWER__.open(){
    local filepath="$1"
    __VIEWER__.load "$filepath"
    __VIEWER__.show
}