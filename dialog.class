#!/bin/bash
# dialog.class - MC-style dialog boxes using ba.sh

# Note: TUI components should be loaded by the main application before using dialog

declare -Ag __DIALOG___properties=()

__DIALOG__.property(){
    if [ "$2" = "=" ]; then
        __DIALOG___properties[$1]="$3"
    else
        echo "${__DIALOG___properties[$1]}"
    fi
}

# Property accessors
__DIALOG__.title(){       __DIALOG__.property title       "$@"; }
__DIALOG__.message(){     __DIALOG__.property message     "$@"; }
__DIALOG__.input_value(){ __DIALOG__.property input_value "$@"; }
__DIALOG__.result(){      __DIALOG__.property result      "$@"; }

# Show input dialog - always returns 0; check dialog.result (0=OK, 1=Cancel)
# Usage: dialog.show_input "Title" "Message" "default_value"
# Result in dialog.input_value
__DIALOG__.show_input(){
    local title="$1"
    local message="$2"
    local default="${3:-}"

    __DIALOG__.title = "$title"
    __DIALOG__.message = "$message"
    __DIALOG__.input_value = "$default"

    tui.cursor.hide

    local size=$(tui.screen.size)
    local rows=${size% *}
    local cols=${size#* }

    local dialog_width=60
    local dialog_height=7
    local max_width=$(( cols - 4 ))
    [ $dialog_width -gt $max_width ] && dialog_width=$max_width
    local inner_width=$(( dialog_width - 4 ))
    local dialog_row=$(( (rows - dialog_height) / 2 ))
    local dialog_col=$(( (cols - dialog_width) / 2 ))

    # Shadow
    tui.color.bg_black
    for ((r=dialog_row+1; r<dialog_row+dialog_height+1; r++)); do
        tui.cursor.move $r $((dialog_col + 2))
        printf "%$((dialog_width))s" ""
    done
    tui.color.reset

    # Background
    tui.color.bg_white; tui.color.black
    for ((r=dialog_row; r<dialog_row+dialog_height; r++)); do
        tui.cursor.move $r $dialog_col
        printf "%${dialog_width}s" ""
    done

    # Border
    tui.color.bg_white; tui.color.black
    tui.box.draw $dialog_row $dialog_col $dialog_width $dialog_height

    # Title
    tui.cursor.move $dialog_row $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    printf " %s " "$title"
    tui.color.reset

    # Message
    tui.cursor.move $((dialog_row + 2)) $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    if [ ${#message} -gt $inner_width ]; then message="...${message: -$((inner_width - 3))}"; fi
    printf "%-${inner_width}s" "$message"

    local input="$(__DIALOG__.input_value)"
    local cursor_pos=${#input}
    local focus=0  # 0=input 1=OK 2=Cancel

    tui.cursor.show

    while true; do
        # Input field
        tui.cursor.move $((dialog_row + 3)) $((dialog_col + 2))
        if [ $focus -eq 0 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "%-${inner_width}s" "$input"
        tui.color.reset

        # OK button (default)
        tui.cursor.move $((dialog_row + 5)) $((dialog_col + dialog_width/2 - 10))
        if [ $focus -eq 1 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "[< OK >]"
        tui.color.reset

        tui.color.bg_white; tui.color.black
        printf "   "

        # Cancel button
        if [ $focus -eq 2 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "[ Cancel ]"
        tui.color.reset

        # Cursor position
        if [ $focus -eq 0 ]; then
            tui.cursor.move $((dialog_row + 3)) $((dialog_col + 2 + cursor_pos))
            tui.cursor.show
        else
            tui.cursor.hide
        fi

        local key=$(tui.input.key)

        case "$key" in
            ENTER)
                tui.cursor.hide
                if [ $focus -eq 2 ]; then
                    __DIALOG__.result = 1
                else
                    __DIALOG__.result = 0
                fi
                return 0
                ;;
            ESC)
                tui.cursor.hide
                __DIALOG__.result = 1
                return 0
                ;;
            TAB|DOWN)
                focus=$(( (focus + 1) % 3 ))
                ;;
            SHIFT-TAB|UP)
                focus=$(( (focus + 2) % 3 ))
                ;;
            LEFT)
                if [ $focus -eq 0 ] && [ $cursor_pos -gt 0 ]; then
                    cursor_pos=$((cursor_pos - 1))
                elif [ $focus -gt 0 ]; then
                    focus=$(( focus - 1 ))
                    [ $focus -lt 1 ] && focus=1
                fi
                ;;
            RIGHT)
                if [ $focus -eq 0 ] && [ $cursor_pos -lt ${#input} ]; then
                    cursor_pos=$((cursor_pos + 1))
                elif [ $focus -gt 0 ]; then
                    focus=$(( focus + 1 ))
                    [ $focus -gt 2 ] && focus=2
                fi
                ;;
            HOME)
                [ $focus -eq 0 ] && cursor_pos=0
                ;;
            END)
                [ $focus -eq 0 ] && cursor_pos=${#input}
                ;;
            BACKSPACE)
                if [ $focus -eq 0 ] && [ $cursor_pos -gt 0 ]; then
                    input="${input:0:$((cursor_pos-1))}${input:$cursor_pos}"
                    cursor_pos=$((cursor_pos - 1))
                    __DIALOG__.input_value = "$input"
                fi
                ;;
            DELETE)
                if [ $focus -eq 0 ] && [ $cursor_pos -lt ${#input} ]; then
                    input="${input:0:$cursor_pos}${input:$((cursor_pos+1))}"
                    __DIALOG__.input_value = "$input"
                fi
                ;;
            *)
                if [ $focus -eq 0 ] && [ ${#key} -eq 1 ]; then
                    input="${input:0:$cursor_pos}${key}${input:$cursor_pos}"
                    cursor_pos=$((cursor_pos + 1))
                    __DIALOG__.input_value = "$input"
                fi
                ;;
        esac
    done
}

# Show confirmation dialog - always returns 0; check dialog.result (0=Yes, 1=No, 2=ESC)
# Usage: dialog.show_confirm "Title" "Question?"
__DIALOG__.show_confirm(){
    local title="$1"
    local message="$2"

    __DIALOG__.title = "$title"
    __DIALOG__.message = "$message"

    tui.cursor.hide

    local size=$(tui.screen.size)
    local rows=${size% *}
    local cols=${size#* }

    local dialog_width=50
    local dialog_height=6
    local max_width=$(( cols - 4 ))
    [ $dialog_width -gt $max_width ] && dialog_width=$max_width
    local inner_width=$(( dialog_width - 4 ))
    local dialog_row=$(( (rows - dialog_height) / 2 ))
    local dialog_col=$(( (cols - dialog_width) / 2 ))

    # Shadow
    tui.color.bg_black
    for ((r=dialog_row+1; r<dialog_row+dialog_height+1; r++)); do
        tui.cursor.move $r $((dialog_col + 2))
        printf "%$((dialog_width))s" ""
    done
    tui.color.reset

    # Background
    tui.color.bg_white; tui.color.black
    for ((r=dialog_row; r<dialog_row+dialog_height; r++)); do
        tui.cursor.move $r $dialog_col
        printf "%${dialog_width}s" ""
    done

    # Border
    tui.color.bg_white; tui.color.black
    tui.box.draw $dialog_row $dialog_col $dialog_width $dialog_height

    # Title
    tui.cursor.move $dialog_row $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    printf " %s " "$title"
    tui.color.reset

    # Message (centered)
    tui.cursor.move $((dialog_row + 2)) $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    if [ ${#message} -gt $inner_width ]; then message="...${message: -$((inner_width - 3))}"; fi
    local msg_len=${#message}
    local padding=$(( (inner_width - msg_len) / 2 ))
    printf "%${padding}s%s" "" "$message"
    tui.color.reset

    local selected=0  # 0=Yes 1=No

    while true; do
        tui.cursor.move $((dialog_row + 4)) $((dialog_col + dialog_width/2 - 8))

        # Yes button (default)
        if [ $selected -eq 0 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "[< Yes >]"
        tui.color.reset

        tui.color.bg_white; tui.color.black
        printf "   "

        # No button
        if [ $selected -eq 1 ]; then
            tui.color.bg_cyan; tui.color.black
        else
            tui.color.bg_white; tui.color.black
        fi
        printf "[ No ]"
        tui.color.reset

        local key=$(tui.input.key)

        case "$key" in
            ENTER)
                [ $selected -eq 0 ] && __DIALOG__.result = 0 || __DIALOG__.result = 1
                return 0
                ;;
            LEFT|RIGHT|TAB|UP|DOWN)
                selected=$(( 1 - selected ))
                ;;
            y|Y)
                __DIALOG__.result = 0
                return 0
                ;;
            n|N)
                __DIALOG__.result = 1
                return 0
                ;;
            ESC)
                __DIALOG__.result = 2
                return 0
                ;;
        esac
    done
}

# Show status dialog - returns immediately (use for progress display)
# Usage: dialog.show_status "Title" "Message text"
__DIALOG__.show_status(){
    local title="$1"
    local message="$2"
    local panel_x="${3:-}"
    local panel_y="${4:-}"
    local panel_w="${5:-}"
    local panel_h="${6:-}"

    tui.cursor.hide

    local area_cols area_rows area_x area_y
    if [ -n "$panel_x" ]; then
        area_x=$panel_x; area_y=$panel_y
        area_cols=$panel_w; area_rows=$panel_h
    else
        local size=$(tui.screen.size)
        area_rows=${size% *}; area_cols=${size#* }
        area_x=1; area_y=1
    fi

    local dialog_width=50
    [ ${#message} -gt 44 ] && dialog_width=$(( ${#message} + 6 ))
    [ $dialog_width -gt $((area_cols - 4)) ] && dialog_width=$((area_cols - 4))
    local dialog_height=5
    local dialog_row=$(( area_y + (area_rows - dialog_height) / 2 ))
    local dialog_col=$(( area_x + (area_cols - dialog_width) / 2 ))

    # Shadow
    tui.color.bg_black
    for ((r=dialog_row+1; r<dialog_row+dialog_height+1; r++)); do
        tui.cursor.move $r $((dialog_col + 2))
        printf "%$((dialog_width))s" ""
    done
    tui.color.reset

    # Background
    tui.color.bg_white; tui.color.black
    for ((r=dialog_row; r<dialog_row+dialog_height; r++)); do
        tui.cursor.move $r $dialog_col
        printf "%${dialog_width}s" ""
    done

    # Border + title
    tui.color.bg_white; tui.color.black
    tui.box.draw $dialog_row $dialog_col $dialog_width $dialog_height
    tui.cursor.move $dialog_row $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    printf " %s " "$title"
    tui.color.reset

    # Message (centered)
    local inner_width=$(( dialog_width - 4 ))
    local msg_bytes=${#message}
    [ $msg_bytes -gt $inner_width ] && message="${message:0:$inner_width}"
    local msg_bytes=${#message}
    local padding=$(( (inner_width - msg_bytes) / 2 ))
    [ $padding -lt 0 ] && padding=0
    local right_pad=$(( inner_width - msg_bytes - padding ))
    [ $right_pad -lt 0 ] && right_pad=0
    tui.cursor.move $((dialog_row + 2)) $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    printf "%${padding}s%s%${right_pad}s" "" "$message" ""
    tui.color.reset
}

# Show message dialog - waits for keypress
# Usage: dialog.show_message "Title" "Message text"
__DIALOG__.show_message(){
    local title="$1"
    local message="$2"

    __DIALOG__.title = "$title"
    __DIALOG__.message = "$message"

    tui.cursor.hide

    local size=$(tui.screen.size)
    local rows=${size% *}
    local cols=${size#* }

    local dialog_width=50
    local dialog_height=6
    local max_width=$(( cols - 4 ))
    [ $dialog_width -gt $max_width ] && dialog_width=$max_width
    local inner_width=$(( dialog_width - 4 ))
    local dialog_row=$(( (rows - dialog_height) / 2 ))
    local dialog_col=$(( (cols - dialog_width) / 2 ))

    # Shadow
    tui.color.bg_black
    for ((r=dialog_row+1; r<dialog_row+dialog_height+1; r++)); do
        tui.cursor.move $r $((dialog_col + 2))
        printf "%$((dialog_width))s" ""
    done
    tui.color.reset

    # Background
    tui.color.bg_white; tui.color.black
    for ((r=dialog_row; r<dialog_row+dialog_height; r++)); do
        tui.cursor.move $r $dialog_col
        printf "%${dialog_width}s" ""
    done

    # Border + title
    tui.color.bg_white; tui.color.black
    tui.box.draw $dialog_row $dialog_col $dialog_width $dialog_height
    tui.cursor.move $dialog_row $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    printf " %s " "$title"
    tui.color.reset

    # Message (centered)
    tui.cursor.move $((dialog_row + 2)) $((dialog_col + 2))
    tui.color.bg_white; tui.color.black
    if [ ${#message} -gt $inner_width ]; then message="...${message: -$((inner_width - 3))}"; fi
    local msg_len=${#message}
    local padding=$(( (inner_width - msg_len) / 2 ))
    printf "%${padding}s%s" "" "$message"
    tui.color.reset

    # OK button (default, always focused)
    tui.cursor.move $((dialog_row + 4)) $((dialog_col + dialog_width/2 - 4))
    tui.color.bg_cyan; tui.color.black
    printf "[< OK >]"
    tui.color.reset

    tui.input.key >/dev/null

    __DIALOG__.result = 0
    return 0
}
